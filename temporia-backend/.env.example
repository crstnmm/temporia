APP_NAME=Temporia
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=temporia
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# ── Session / Cookie Security ──────────────────────────────────────────────────
# same_site=strict: cookie only sent in first-party context (primary CSRF mitigation)
# secure=true: cookie only sent over HTTPS
# http_only=true: cookie inaccessible to JavaScript (prevents XSS token theft)
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# ── Sanctum ────────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=yourdomain.com
FRONTEND_URL=https://yourdomain.com
FRONTEND_PREVIEW_URL=https://yourdomain.com

# ── Never commit real credentials — use a secrets manager in production ────────
